
/felixo-standards

# Segredos
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Dados coletados — ignora tudo em data/ EXCETO o banco, que é versionado
# para o site rodar direto após o clone (são componentes públicos, sem segredos).
scraper/data/*
!scraper/data/components.db
scraper/debug_html/
scraper/.cache/

# Site — frontend (Node/Vite)
site/frontend/node_modules/
site/frontend/dist/
