# Token do GitHub (classic, sem scopes necessários para repos públicos)
# Gere em: https://github.com/settings/tokens
# Aumenta o rate limit de 60 -> 5000 requisições/hora
GITHUB_TOKEN=

# Limites opcionais (têm defaults em config.py)
# SCRAPER_MAX_COMPONENTS=500
# SCRAPER_REQUEST_DELAY=0.5
# SCRAPER_TIMEOUT_MS=30000
